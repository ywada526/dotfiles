{
  "permissions": {
    "ask": [
      "Bash(sudo:*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1 || exit 0; out=$(git pull --ff-only 2>&1); printf '{\"systemMessage\": %s}' \"$(printf 'git pull --ff-only:\\n%s' \"$out\" | jq -Rsa .)\"",
            "statusMessage": "Syncing branch with remote..."
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false,
  "theme": "auto",
  "verbose": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
