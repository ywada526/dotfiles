{
  "permissions": {
    "ask": [
      "Bash(sudo:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1 || exit 0; out=$(git pull --ff-only 2>&1); printf '{\"systemMessage\": %s}' \"$(printf 'git pull --ff-only:\\n%s' \"$out\" | jq -Rsa .)\"",
            "statusMessage": "Syncing branch with remote..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "crit@crit": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    }
  },
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "verbose": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
