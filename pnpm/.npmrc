# pnpm-specific globals. Symlinked into ~/.config/pnpm/rc by install.sh
# (XDG_CONFIG_HOME is set in shell/.zshenv, so pnpm's globalconfig lives
# under ~/.config/pnpm/rc).
#
# npm-shared settings (e.g. save-exact) live in npm/.npmrc → ~/.npmrc.
# pnpm reads both files; this one carries pnpm-only keys that npm would
# warn about as "Unknown user config".

# Hard-fail install if a dep needs an unapproved build script.
strict-dep-builds=true

# Cooldown — skip versions younger than 14 days (pnpm wants minutes).
# Format conflicts with npm's duration-string format, hence the file split.
min-release-age=20160

# Reject installing a less-trusted version than previously seen.
trust-policy=no-downgrade
