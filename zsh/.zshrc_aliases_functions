# shellcheck disable=SC2148

# Route package manager invocations through Socket Firewall (sfw-free) for
# pre-install threat intel + malicious package blocking.
# uvx is a separate binary (uv tool run shorthand) so it needs its own alias.
# Not covered by sfw-free free tier: go install / gem install / curl | sh —
# these remain unguarded. Be deliberate.
alias pnpm="sfw-free pnpm"
alias pip="sfw-free pip"
alias uv="sfw-free uv"
alias uvx="sfw-free uvx"
alias cargo="sfw-free cargo"
