# npm config. pnpm reads ~/.npmrc too, so only put settings here that
# pnpm is OK with (or that we override per-process via env vars in the
# npm() wrapper in security/blockers.sh).
#
# pnpm-only settings live in pnpm/.npmrc → ~/.config/pnpm/rc.

save-exact=true
fund=false

# npm 11.10+ supports min-release-age as a duration string. We don't put
# it here because pnpm would misparse the value (pnpm wants minutes); the
# npm() wrapper injects NPM_CONFIG_MIN_RELEASE_AGE=14d per invocation
# instead, so the cooldown only applies to npm.
#
# ignore-scripts=true is similarly NOT set here (it would block pnpm's
# allowlist mechanism). The npm() wrapper sets NPM_CONFIG_IGNORE_SCRIPTS=true
# so postinstall is blocked for npm only.
