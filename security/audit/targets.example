# scan-all.sh reads paths/globs from `targets` (gitignored, copy this
# file as a starting point). One entry per line. `~` and globs are
# expanded by the shell. Lines starting with `#` are comments.

# Personal repos
~/dotfiles

# Repos under ghq layout
~/ghq/github.com/<org>/*

# Specific high-priority projects
# ~/ghq/github.com/<org>/critical-app
